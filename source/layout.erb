<!doctype html>
<html>
  <head>
    <script type="text/javascript" src="//use.typekit.net/kta6ruk.js"></script>
    <script type="text/javascript">try{Typekit.load();}catch(e){}</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width">
    <meta http-equiv='X-UA-Compatible' content='IE=edge;chrome=1' />
    <title>Kyle Shank<%= ' - ' + current_article.title unless current_article.nil? %></title>
    <%= feed_tag :rss, "#{blog.options.prefix.to_s}/rss.xml", title: "RSS Feed" %>
    <%= stylesheet_link_tag  "all" %>

    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js"></script>
    <link rel="stylesheet" href="//maxcdn.bootstrapcdn.com/bootstrap/3.2.0/css/bootstrap.min.css">
    <script src="//maxcdn.bootstrapcdn.com/bootstrap/3.2.0/js/bootstrap.min.js"></script>
    <link href="//maxcdn.bootstrapcdn.com/font-awesome/4.1.0/css/font-awesome.min.css" rel="stylesheet">

    <script type="text/javascript">

      var _gaq = _gaq || [];
      _gaq.push(['_setAccount', 'UA-2236980-7']);
      _gaq.push(['_trackPageview']);

      (function() {
        var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;
        ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';
        var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);
      })();

    </script>
  </head>
  <body>
    <nav class="navbar navbar-default" role="navigation">
      <div class="container">
        <!-- Brand and toggle get grouped for better mobile display -->
        <div class="navbar-header">
          <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#navbar-collapse">
            <span class="sr-only">Toggle navigation</span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          <a class="navbar-brand" href="/">Kyle Shank</a>
        </div>

        <!-- Collect the nav links, forms, and other content for toggling -->
        <div class="collapse navbar-collapse" id="navbar-collapse">
          <ul class="nav navbar-nav">
            <li class="dropdown">
              <a href="#" class="dropdown-toggle" data-toggle="dropdown">Projects <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li><%=link_to "apt-s3", "http://github.com/kyleshank/apt-s3"%></li>
                <li><%=link_to "Cloudgram", "/2013/12/12/cloudgram-release.html"%></li>
                <li><%=link_to "Donate Your Account", "http://donateyouraccount.com"%></li>
                <li><%=link_to "FANS.FM", "http://fans.fm"%></li>
                <li><%=link_to "FMAssetStream", "https://github.com/formal-method/FMAssetStream"%></li>
                <li><%=link_to "FMImagePickerController", "https://github.com/formal-method/FMImagePickerController"%></li>
                <li><%=link_to "FMNowPlayingBarButtonItem", "https://github.com/formal-method/FMNowPlayingBarButtonItem"%></li>
                <li><%=link_to "FMProgressViewController", "https://github.com/formal-method/FMProgressViewController"%></li>
                <li><%=link_to "RadRails", "http://en.wikipedia.org/wiki/RadRails"%></li>
                <li><%=link_to "Swipe Stopper", "/2013/12/30/swipe-stopper.html"%></li>
              </ul>
            </li>
            <li class="dropdown">
              <a href="#" class="dropdown-toggle" data-toggle="dropdown">Archives <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li><%=link_to "2014", "/2014.html"%></li>
                <li><%=link_to "2013", "/2013.html"%></li>
              </ul>
            </li>
            <li><a href="/about.html">About</a></li>
            <li><a href="http://twitter.com/kyleshank"><i class="fa fa-twitter hidden-xs"></i><span class="visible-xs">Twitter</span></a></li>
            <li><a href="http://github.com/kyleshank"><i class="fa fa-github hidden-xs"></i><span class="visible-xs">Github</span></a></li>
            <li><a href="http://linkedin.com/in/kyleshank"><i class="fa fa-linkedin hidden-xs"></i><span class="visible-xs">LinkedIn</span></a></li>
            <li><a href="http://www.kyleshank.com/rss.xml"><i class="fa fa-rss hidden-xs"></i><span class="visible-xs">RSS</span></a></li>
          </ul>
        </div><!-- /.navbar-collapse -->
      </div><!-- /.container-fluid -->
    </nav>

    <div class="container">
      <% if current_article %>
        <article>
          <h1><%=current_article.title%></h1>

          <%=yield%>

          <time><%= current_article.date.strftime('%B %e, %Y') %></time>
        </article>
      <% else %>
        <%=yield%>
      <% end %>
    </div>
  </body>
</html>
